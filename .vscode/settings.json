{
  // Schema validation
  "json.schemas": [
    {
      "fileMatch": [".vscode/settings.json"],
      "schema": {
        "type": "object"
      }
    }
  ],

  // Python test discovery and runner
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],

  // Cross-platform: use workspaceFolder for terminal cwd
  "terminal.integrated.cwd": "${workspaceFolder}",

  // Editor settings for consistent formatting
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // Python-specific settings
  "python.analysis.typeCheckingMode": "basic",
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  // Live Server preview for Figma HTML mocky
  "liveServer.settings.port": 5500,
  "liveServer.settings.host": "127.0.0.1",
  "liveServer.settings.root": "./frontend/figma",
  "liveServer.settings.file": "menumat-redesign.html",
  "liveServer.settings.wait": 0,
  "liveServer.settings.NoBrowser": false,
  "liveServer.settings.ignoreFiles": [
    "**/*.pyc",
    "**/__pycache__/**"
  ],
  "liveServer.settings.AdvanceCustomBrowserCmdLine": "",
  "telemetry.editStats.showStatusBar": true,
  "files.autoSave": "onWindowChange",
  "editor.defaultFormatter": "vscode.css-language-features",
  "editor.mouseWheelZoom": true,
  "editor.formatOnPaste": true,
  "editor.allowVariableFontsInAccessibilityMode": true,
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingComments": "always",
  "editor.autoIndentOnPaste": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.codeActions.triggerOnFocusChange": true,
  "editor.defaultFoldingRangeProvider": "GitHub.copilot-chat",
  "editor.definitionLinkOpensInPeek": true,
  "editor.experimental.asyncTokenizationLogging": true,
  "editor.hideCursorInOverviewRuler": true,
  "editor.linkedEditing": true,
  "editor.tabFocusMode": true,
  "editor.trimWhitespaceOnDelete": true,
  "editor.unfoldOnClickAfterEndOfLine": false,
  "editor.aiStats.enabled": true,
  "editor.experimental.asyncTokenizationVerification": true,
  "editor.experimental.preferTreeSitter.css": true,
  "editor.experimental.preferTreeSitter.typescript": true,
  "editor.experimentalGpuAcceleration": "on",
  "diffEditor.codeLens": true,
  "editor.formatOnType": true,
  "diffEditor.experimental.showMoves": true,
  "diffEditor.experimental.useTrueInlineView": true,
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.inlineSuggest.triggerCommandOnProviderChange": true,
  "files.autoSaveWhenNoErrors": true,
  "files.autoSaveWorkspaceFilesOnly": true,
  "files.readonlyFromPermissions": true,
  "workbench.browser.openLocalhostLinks": true,
  "workbench.commandPalette.preserveInput": true,
  "workbench.externalUriOpeners": {
    "workbench.externalUriOpeners": "simpleBrowser.open"
  },
  "workbench.experimental.cloudChanges.partialMatches.enabled": true,
  "workbench.experimental.share.enabled": true,
  "workbench.secondarySideBar.forceMaximized": false,
  "workbench.activityBar.compact": true,
  "workbench.activityBar.autoHide": true,
  "xlsxViewer.csv.firstRowIsHeader": true,
  "xlsxViewer.csv.stickyHeader": true,
  "xlsxViewer.tsv.firstRowIsHeader": true,
  "xlsxViewer.tsv.stickyHeader": true
}
